{
  "name": "@restaurant-pos/db",
  "version": "0.1.0",
  "private": true,
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "prisma:generate": "prisma generate --config prisma.config.ts",
    "prisma:validate": "prisma validate --config prisma.config.ts",
    "prisma:migrate": "prisma migrate dev --config prisma.config.ts",
    "prisma:seed": "prisma db seed --config prisma.config.ts"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "pg": "^8.21.0"
  },
  "devDependencies": {
    "@types/node": "^25.9.2",
    "bcryptjs": "^3.0.3",
    "dotenv": "^17.4.2",
    "prisma": "^7.8.0",
    "tsx": "^4.22.4"
  }
}
