  @@map("order_item_modifiers")
}

model Payment {
  id                        String          @id @default(uuid()) @db.Uuid
  companyId                 String          @map("company_id") @db.Uuid
  outletId                  String          @map("outlet_id") @db.Uuid
  orderId                   String          @map("order_id") @db.Uuid
  provider                  PaymentProvider
  method                    PaymentMethod
  status                    PaymentStatus   @default(CREATED)
  amountCents               Int             @map("amount_cents")
  currency                  String          @db.Char(3)
  manualReference           String?         @map("manual_reference") @db.VarChar(160)
  creationIdempotencyKey    String?         @unique @map("creation_idempotency_key") @db.VarChar(120)
  verificationIdempotencyKey String?        @unique @map("verification_idempotency_key") @db.VarChar(120)
  stripeCheckoutSessionId   String?         @unique @map("stripe_checkout_session_id") @db.VarChar(255)
  stripeCheckoutUrl         String?         @map("stripe_checkout_url")
  stripePaymentIntentId     String?         @unique @map("stripe_payment_intent_id") @db.VarChar(255)
  stripeChargeId            String?         @unique @map("stripe_charge_id") @db.VarChar(255)
  checkoutExpiresAt         DateTime?       @map("checkout_expires_at") @db.Timestamptz(6)
  providerFeeCents          Int?            @map("provider_fee_cents")
  netAmountCents            Int?            @map("net_amount_cents")
  verifiedByUserId          String?         @map("verified_by_user_id") @db.Uuid
  verifiedAt                DateTime?       @map("verified_at") @db.Timestamptz(6)
  paidAt                    DateTime?       @map("paid_at") @db.Timestamptz(6)
  failedAt                  DateTime?       @map("failed_at") @db.Timestamptz(6)
  failureReason             String?         @map("failure_reason")
  createdAt                 DateTime        @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt                 DateTime        @updatedAt @map("updated_at") @db.Timestamptz(6)
  company                   Company         @relation(fields: [companyId], references: [id], onDelete: Restrict)
  outlet                    Outlet          @relation(fields: [outletId], references: [id], onDelete: Restrict)
  order                     Order           @relation(fields: [orderId], references: [id], onDelete: Restrict)
  verifiedBy                User?           @relation("PaymentVerifiedBy", fields: [verifiedByUserId], references: [id], onDelete: SetNull)
  webhookEvents             WebhookEvent[]

  @@index([orderId, status])
  @@index([outletId, method, status, createdAt(sort: Desc)])
  @@map("payments")
}

model WebhookEvent {
  id              String             @id @default(uuid()) @db.Uuid
  companyId       String?            @map("company_id") @db.Uuid
  outletId        String?            @map("outlet_id") @db.Uuid
