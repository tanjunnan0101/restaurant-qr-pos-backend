  preparationStationKey String              @map("preparation_station_key") @db.VarChar(80)
  quantity              Int
  baseUnitPriceCents    Int                 @map("base_unit_price_cents")
  modifierUnitCents     Int                 @default(0) @map("modifier_unit_cents")
  unitPriceCents        Int                 @map("unit_price_cents")
