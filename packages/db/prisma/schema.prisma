}

model DiningTable {
  id          String            @id @default(uuid()) @db.Uuid
  companyId   String            @map("company_id") @db.Uuid
  outletId    String            @map("outlet_id") @db.Uuid
  zoneId      String            @map("zone_id") @db.Uuid
  tableCode   String            @map("table_code") @db.VarChar(40)
  displayName String            @map("display_name") @db.VarChar(120)
  capacity    Int               @default(2)
  shape       DiningTableShape  @default(SQUARE)
  status      DiningTableStatus @default(AVAILABLE)
  active      Boolean           @default(true)
  createdAt   DateTime          @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime          @updatedAt @map("updated_at") @db.Timestamptz(6)
