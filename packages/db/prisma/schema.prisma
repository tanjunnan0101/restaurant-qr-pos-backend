model PrintJob {
  id                String         @id @default(uuid()) @db.Uuid
  companyId         String         @map("company_id") @db.Uuid
  outletId          String         @map("outlet_id") @db.Uuid
  orderId           String?        @map("order_id") @db.Uuid
  kitchenTicketId   String?        @map("kitchen_ticket_id") @db.Uuid
  printerId         String?        @map("printer_id") @db.Uuid
  template          PrintTemplate
  payloadJson       Json           @map("payload_json")
  renderedText      String         @map("rendered_text")
  status            PrintJobStatus @default(QUEUED)
  priority          Int            @default(100)
  attemptCount      Int            @default(0) @map("attempt_count")
  maxAttempts       Int            @default(5) @map("max_attempts")
  nextAttemptAt     DateTime        @default(now()) @map("next_attempt_at") @db.Timestamptz(6)
  leasedByAgentId   String?         @map("leased_by_agent_id") @db.Uuid
  leaseExpiresAt    DateTime?       @map("lease_expires_at") @db.Timestamptz(6)
  lastError         String?         @map("last_error")
  backupRouted      Boolean         @default(false) @map("backup_routed")
  printedAt         DateTime?       @map("printed_at") @db.Timestamptz(6)
  cancelledAt       DateTime?       @map("cancelled_at") @db.Timestamptz(6)
  reprintOfId       String?         @map("reprint_of_id") @db.Uuid
  createdAt         DateTime        @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt         DateTime        @updatedAt @map("updated_at") @db.Timestamptz(6)
  company           Company         @relation(fields: [companyId], references: [id], onDelete: Restrict)
  outlet            Outlet          @relation(fields: [outletId], references: [id], onDelete: Restrict)
  order             Order?          @relation(fields: [orderId], references: [id], onDelete: Cascade)
  kitchenTicket     KitchenTicket?  @relation(fields: [kitchenTicketId], references: [id], onDelete: Cascade)
  printer           Printer?        @relation(fields: [printerId], references: [id], onDelete: SetNull)
  leasedByAgent     PrinterAgent?    @relation(fields: [leasedByAgentId], references: [id], onDelete: SetNull)
  attempts          PrintJobAttempt[]
  reprintOf         PrintJob?        @relation("PrintJobReprints", fields: [reprintOfId], references: [id], onDelete: SetNull)
  reprints          PrintJob[]       @relation("PrintJobReprints")

  @@index([outletId, status, priority, createdAt])
  @@index([printerId, status, nextAttemptAt])
  @@map("print_jobs")
}

model PrintJobAttempt {
  id            String             @id @default(uuid()) @db.Uuid
  printJobId    String             @map("print_job_id") @db.Uuid
  agentId       String             @map("agent_id") @db.Uuid
  attemptNumber Int                @map("attempt_number")
  status        PrintAttemptStatus
  errorMessage  String?            @map("error_message")
  startedAt     DateTime           @default(now()) @map("started_at") @db.Timestamptz(6)
  completedAt   DateTime?          @map("completed_at") @db.Timestamptz(6)
