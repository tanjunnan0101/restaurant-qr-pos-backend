model Printer {
  id                String                @id @default(uuid()) @db.Uuid
  companyId         String                @map("company_id") @db.Uuid
  outletId          String                @map("outlet_id") @db.Uuid
  key               String                @db.VarChar(80)
  name              String                @db.VarChar(120)
  connectionType    PrinterConnectionType @map("connection_type")
  role              PrinterRole
  host              String?               @db.VarChar(255)
  port              Int?
  paperWidthMm      Int                   @default(80) @map("paper_width_mm")
  autoCut           Boolean               @default(true) @map("auto_cut")
  buzzer            Boolean               @default(false)
  cashDrawer        Boolean               @default(false) @map("cash_drawer")
  active            Boolean               @default(true)
  healthStatus      PrinterHealthStatus   @default(UNKNOWN) @map("health_status")
  lastHeartbeatAt   DateTime?             @map("last_heartbeat_at") @db.Timestamptz(6)
  lastTestAt        DateTime?             @map("last_test_at") @db.Timestamptz(6)
  lastTestResult    String?               @map("last_test_result")
  createdAt         DateTime              @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt         DateTime              @updatedAt @map("updated_at") @db.Timestamptz(6)
  company           Company               @relation(fields: [companyId], references: [id], onDelete: Cascade)
  outlet            Outlet                @relation(fields: [outletId], references: [id], onDelete: Cascade)
  primaryRoutes     PrinterRoute[]         @relation("PrimaryPrinter")
  backupRoutes      PrinterRoute[]         @relation("BackupPrinter")
  printJobs         PrintJob[]

  @@unique([outletId, key])
  @@index([companyId, outletId, active])
  @@map("printers")
}

model PrinterRoute {
  id              String         @id @default(uuid()) @db.Uuid
  companyId       String         @map("company_id") @db.Uuid
  outletId        String         @map("outlet_id") @db.Uuid
  stationId       String         @unique @map("station_id") @db.Uuid
  primaryPrinterId String        @map("primary_printer_id") @db.Uuid
  backupPrinterId String?        @map("backup_printer_id") @db.Uuid
  createdAt       DateTime       @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime       @updatedAt @map("updated_at") @db.Timestamptz(6)
  company         Company        @relation(fields: [companyId], references: [id], onDelete: Cascade)
  outlet          Outlet         @relation(fields: [outletId], references: [id], onDelete: Cascade)
  station         KitchenStation @relation(fields: [stationId], references: [id], onDelete: Cascade)
  primaryPrinter  Printer        @relation("PrimaryPrinter", fields: [primaryPrinterId], references: [id], onDelete: Restrict)
  backupPrinter   Printer?       @relation("BackupPrinter", fields: [backupPrinterId], references: [id], onDelete: SetNull)

  @@index([companyId, outletId])
  @@map("printer_routes")
}

model PrinterAgent {
  id              String    @id @default(uuid()) @db.Uuid
  companyId       String    @map("company_id") @db.Uuid
  outletId        String    @map("outlet_id") @db.Uuid
