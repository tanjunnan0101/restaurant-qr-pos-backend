  @@index([companyId, outletId, status])
  @@index([tableId, createdAt(sort: Desc)])
  @@map("table_sessions")
}

model OrderSequence {
  outletId     String   @map("outlet_id") @db.Uuid
  businessDate DateTime @map("business_date") @db.Date
  lastNumber   Int      @default(0) @map("last_number")
  updatedAt    DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@id([outletId, businessDate])
  @@map("order_sequences")
}

model Order {
  id                     String             @id @default(uuid()) @db.Uuid
  companyId              String             @map("company_id") @db.Uuid
  outletId               String             @map("outlet_id") @db.Uuid
  tableId                String?            @map("table_id") @db.Uuid
  tableSessionId         String?            @map("table_session_id") @db.Uuid
  orderNumber            String             @map("order_number") @db.VarChar(40)
  businessDate           DateTime           @map("business_date") @db.Date
  source                 OrderSource
  serviceType            ServiceType        @map("service_type")
  status                 OrderStatus        @default(PENDING_PAYMENT)
  paymentStatus          OrderPaymentStatus @default(PENDING) @map("payment_status")
  currency               String             @db.Char(3)
  subtotalCents          Int                @map("subtotal_cents")
  discountTotalCents     Int                @default(0) @map("discount_total_cents")
  serviceChargeTotalCents Int               @default(0) @map("service_charge_total_cents")
  gstTotalCents          Int                @default(0) @map("gst_total_cents")
  roundingAdjustmentCents Int               @default(0) @map("rounding_adjustment_cents")
  grandTotalCents        Int                @map("grand_total_cents")
  idempotencyKey         String             @map("idempotency_key") @db.VarChar(120)
  requestFingerprint     String             @map("request_fingerprint") @db.Char(64)
  customerName           String?            @map("customer_name") @db.VarChar(160)
  customerPhone          String?            @map("customer_phone") @db.VarChar(40)
  createdByUserId        String?            @map("created_by_user_id") @db.Uuid
  paidAt                 DateTime?           @map("paid_at") @db.Timestamptz(6)
  sentToKitchenAt        DateTime?           @map("sent_to_kitchen_at") @db.Timestamptz(6)
  completedAt            DateTime?           @map("completed_at") @db.Timestamptz(6)
  cancelledAt            DateTime?           @map("cancelled_at") @db.Timestamptz(6)
  createdAt              DateTime            @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt              DateTime            @updatedAt @map("updated_at") @db.Timestamptz(6)
  company                Company             @relation(fields: [companyId], references: [id], onDelete: Restrict)
  outlet                 Outlet              @relation(fields: [outletId], references: [id], onDelete: Restrict)
  table                  DiningTable?        @relation(fields: [tableId], references: [id], onDelete: Restrict)
  tableSession           TableSession?       @relation(fields: [tableSessionId], references: [id], onDelete: Restrict)
  createdBy              User?               @relation("OrderCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)
  items                  OrderItem[]
  payments               Payment[]
  kitchenTickets         KitchenTicket[]
  printJobs              PrintJob[]

  @@unique([companyId, idempotencyKey])
  @@unique([outletId, businessDate, orderNumber])
  @@index([outletId, status, createdAt(sort: Desc)])
  @@index([companyId, paymentStatus, createdAt(sort: Desc)])
  @@map("orders")
}

model OrderItem {
  id                    String              @id @default(uuid()) @db.Uuid
  companyId             String              @map("company_id") @db.Uuid
  orderId               String              @map("order_id") @db.Uuid
