  outlet          Outlet      @relation(fields: [outletId], references: [id], onDelete: Cascade)
  table           DiningTable @relation(fields: [tableId], references: [id], onDelete: Cascade)

  @@index([companyId, outletId, active])
  @@index([tableId, active])
  @@map("qr_codes")
}

model TableSession {
  id             String             @id @default(uuid()) @db.Uuid
  companyId      String             @map("company_id") @db.Uuid
  outletId       String             @map("outlet_id") @db.Uuid
  tableId        String             @map("table_id") @db.Uuid
  activeTableKey String?            @unique @map("active_table_key") @db.Uuid
  status         TableSessionStatus @default(SEATED)
  seatedAt       DateTime           @default(now()) @map("seated_at") @db.Timestamptz(6)
  closedAt       DateTime?          @map("closed_at") @db.Timestamptz(6)
