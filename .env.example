NODE_ENV=development
PORT=3001
API_CORS_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:3002,http://localhost:3003
API_TRUST_PROXY=true
SWAGGER_ENABLED=true

DATABASE_URL=postgresql://restaurant_pos:restaurant_pos@localhost:5432/restaurant_pos?schema=public
REDIS_URL=redis://localhost:6379

JWT_SECRET=replace-with-at-least-32-random-characters
JWT_EXPIRES_IN_SECONDS=3600
PLATFORM_ADMIN_API_KEY=replace-with-at-least-32-random-characters
OWNER_APP_BASE_URL=http://localhost:3002
CUSTOMER_APP_BASE_URL=http://localhost:3000
NEXT_PUBLIC_API_BASE_URL=http://localhost:3001/api/v1
ONBOARDING_TOKEN_TTL_HOURS=72

HITPAY_API_KEY=
HITPAY_WEBHOOK_SALT=
HITPAY_API_URL=https://api.sandbox.hit-pay.com

RATE_LIMIT_ENABLED=true
RATE_LIMIT_AUTH_WINDOW_MS=300000
RATE_LIMIT_AUTH_MAX=20
RATE_LIMIT_PUBLIC_WINDOW_MS=60000
RATE_LIMIT_PUBLIC_MAX=120
RATE_LIMIT_ADMIN_WINDOW_MS=60000
RATE_LIMIT_ADMIN_MAX=300
REQUEST_LOGGING_ENABLED=true
REQUEST_LOGGING_SLOW_MS=1500
ERROR_TRACKING_ENABLED=true
ERROR_WEBHOOK_URL=

SEED_OWNER_EMAIL=owner@example.com
SEED_OWNER_PASSWORD=ChangeMe123!
